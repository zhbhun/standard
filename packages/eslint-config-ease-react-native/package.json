{
  "name": "eslint-config-ease-react-native",
  "version": "2.0.0",
  "description": "ESLint React Native config, following our styleguide",
  "main": "index.js",
  "license": "MIT",
  "homepage": "https://github.com/zhbhun/standard",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhbhun/standard"
  },
  "bugs": {
    "url": "https://github.com/zhbhun/standard/issues"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "config",
    "javascript",
    "react",
    "react-native",
    "styleguide"
  ],
  "engines": {
    "node": ">= 6"
  },
  "files": [
    "rules",
    "index.js"
  ],
  "scripts": {
    "format": "eslint --fix ./index.js ./rules",
    "lint": "eslint ./index.js ./rules",
    "test:format": "eslint --fix ./example",
    "test:lint": "eslint ./example"
  },
  "dependencies": {
    "eslint-config-ease-react": "^2.0.0",
    "eslint-plugin-react-native": "^3.2.1"
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.7.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-config-airbnb-base": "^13.1.0",
    "eslint-config-ease-base": "^2.0.0",
    "eslint-config-prettier": "^3.1.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jsx-a11y": "^6.1.1",
    "eslint-plugin-prettier": "^3.0.0",
    "eslint-plugin-react": "^7.11.0",
    "prettier": "^1.14.3",
    "prettier-config-ease": "^2.0.0"
  }
}
